# ===========================================
# Docker Compose 环境变量配置
# ===========================================

# -------------------------------------------
# MySQL 配置
# -------------------------------------------
MYSQL_DATABASE=mitedtsm_database
MYSQL_ROOT_PASSWORD=1234

# -------------------------------------------
# Redis 配置
# -------------------------------------------
REDIS_HOST=redis

# -------------------------------------------
# TDengine 配置
# -------------------------------------------
TDENGINE_HOST=tdengine
TDENGINE_PORT=6041
TDENGINE_USER=root
TDENGINE_PASSWORD=taosdata
TDENGINE_DATABASE=mitedtsm_database

# -------------------------------------------
# Server 后端配置
# -------------------------------------------
SERVER_PORT=8080
JAVA_OPTS=-Xms512m -Xmx512m -Djava.security.egd=file:/dev/./urandom

# -------------------------------------------
# Web 前端配置
# -------------------------------------------
WEB_PORT=80

# -------------------------------------------
# Mall 前端配置
# -------------------------------------------
MALL_PORT=81
